    font-weight: 600;
    color: var(--black);
    text-decoration: none;
    border: 1.5px solid var(--black);
    padding: 0.65rem 1.5rem;
    border-radius: 8px;
    transition: background var(--transition), color var(--transition);
  }
  .back-btn:hover { background: var(--black); color: var(--white); }

  /* FOOTER */
  .journey-footer {
