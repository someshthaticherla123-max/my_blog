    font-size: clamp(1.05rem, 2vw, 1.3rem);
    font-style: italic;
    color: var(--gray-600);
    line-height: 1.9;
    max-width: 700px;
    margin: 0 auto;
  }
  .reflection-footer { display: flex; flex-direction: column; align-items: center; gap: 1.5rem; }
  .reflection-divider { width: 40px; height: 1px; background: var(--gray-300); }
  .reflection-byline { font-size: 0.85rem; color: var(--gray-400); }
