          <a href="https://code.visualstudio.com" target="_blank" rel="noopener" class="tool-link">Visit Website ↗</a>
        </div>
      </div>

      <div class="tool-card">
        <img src="https://github.com/favicon.ico" alt="GitHub" class="tool-logo" onerror="this.style.display='none'" />
